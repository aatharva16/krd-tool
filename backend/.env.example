# Backend environment variables
# Copy this file to .env and fill in the values

# ─── Server ──────────────────────────────────────────────
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ─── Phase 1a: OpenRouter (LLM integration) ──────────────
# Required. Get your key at https://openrouter.ai → Keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional. Defaults to anthropic/claude-sonnet-4-5 if not set.
# Override to test different models (e.g. openai/gpt-4o).
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Required by OpenRouter as the HTTP-Referer header.
# Set to your local frontend URL during development.
# Update to your Vercel production URL in Phase 6.
APP_URL=http://localhost:5173

# ─── Phase 2: Supabase (database) ────────────────────────
# Required from Phase 2 onward. Get from:
# Supabase project → Settings → API → Project URL & service_role key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
